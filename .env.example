# Copy to .env (which is gitignored) and fill in.
# Cloudflare API *token* (not the legacy global key) with Zone:DNS:Edit
# permission on the chezbg.one zone. Shared by every project's DNS-01 challenge.
CLOUDFLARE_API_KEY=replace-with-cloudflare-api-token

# ACME contact email for Let's Encrypt (expiry/renewal-failure notices).
# Kept here rather than in compose.yaml so it stays out of the public repo.
ACME_EMAIL=you@chezbg.one
